# Copy to .env for local development:  cp .env.example .env
# On Railway, set these in the service's Variables tab instead (do NOT commit .env).

# ---- Server ----
# Port the Express server listens on. Railway sets PORT automatically;
# locally it defaults to 3000 if unset.
PORT=3000

# Base URL prepended to image paths by the client renderer.
# Leave EMPTY to serve images locally from /assets/img.
# Set to your Cloudflare R2 custom domain to serve images from R2:
#   ASSET_BASE_URL=https://cdn.jonathan-freier.com
ASSET_BASE_URL=

# ---- Cloudflare R2 (only needed to run `npm run upload:r2`) ----
# Cloudflare account ID (Dashboard → R2 → shown in the endpoint / account settings)
R2_ACCOUNT_ID=
# R2 API token credentials (Dashboard → R2 → Manage API Tokens → Create)
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
# Target bucket name
R2_BUCKET=jonfrei-assets
# Optional: override the S3 endpoint (defaults to the account R2 URL)
# R2_ENDPOINT=
# Optional: key prefix for uploaded assets (keep "assets/" to match JSON paths)
R2_PREFIX=assets/
