# Copy to .env for local development:  cp .env.example .env
# On Railway, set these in the service's Variables tab instead (do NOT commit .env).

# ---- Server ----
# Port the server listens on. Railway sets PORT automatically; locally SvelteKit
# uses its own dev port (5173) for `npm run dev`.
PORT=3000

# Base URL prepended to image paths. Empty => images served locally from
# /assets/img. Set to your Cloudflare R2 custom domain to serve from R2:
#   ASSET_BASE_URL=https://cdn.jonathan-freier.com
ASSET_BASE_URL=

# ---- Database (Phase 4 admin) ----
# Postgres connection string. Railway provides this automatically when you add a
# Postgres plugin (reference it as ${{Postgres.DATABASE_URL}}). If unset, the app
# falls back to reading static/data/projects.json (read-only, no admin writes).
DATABASE_URL=

# ---- Admin auth (Phase 4) ----
# Two ways to set the admin password (if both are set, the HASH wins):
#   1. ADMIN_PASSWORD_HASH — argon2 hash. Preferred; nothing sensitive is stored.
#        Generate with: node scripts/hash-password.mjs "your-strong-password"
#   2. PASSWORD — plaintext. Simpler, but the raw password is stored in the env.
ADMIN_PASSWORD_HASH=
# PASSWORD=your-plaintext-password   # (only used when ADMIN_PASSWORD_HASH is empty)
# Random secret used to sign session cookies (any long random string). Generate:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# ---- Cloudflare R2 ----
# SERVER upload token (for admin image uploads). SEPARATE from the local upload
# script's token — mint a dedicated one scoped to the bucket.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=jonfrei-assets
# Optional overrides:
# R2_ENDPOINT=
R2_PREFIX=assets/
